{
	"author": "Lyubomyr Shaydariv",
	"background": {
		"service_worker": "main.js",
		"type": "module"
	},
	"description": "Removes tracking parameters and bypasses tracking redirections at some sites",
	"icons": {
		"48": "icon-48x48.png",
		"128": "icon-128x128.png"
	},
	"manifest_version": 3,
	"name": "uU (untrack URLs)",
	"options_ui": {
		"page": "options.html"
	},
	"permissions": [
		"webRequest"
	],
	"short_name": "uU",
	"version": "0.0.35",
	"web_accessible_resources": [{
		"resources": [
			"warn.html",
			"commons.css",
			"warn.js"
		],
		"matches": [
			"*://*/*"
		]
	}]
}
