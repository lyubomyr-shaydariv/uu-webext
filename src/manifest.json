{
	"author": "Lyubomyr Shaydariv",
	"background": {
		"service_worker": "main.js",
		"type": "module"
	},
	"content_security_policy": "object-src 'self'; script-src 'self';",
	"description": "Removes tracking parameters and bypasses tracking redirections at some sites",
	"developer": {
		"name": "Lyubomyr Shaydariv",
		"url": "https://github.com/lyubomyr-shaydariv/"
	},
	"icons": {
		"48": "icon-48x48.png",
		"128": "icon-128x128.png"
	},
	"manifest_version": 3,
	"name": "uU (untrack URLs)",
	"options_ui": {
		"page": "options.html"
	},
	"permissions": [
		"<all_urls>",
		"webRequest",
		"webRequestBlocking"
	],
	"short_name": "uU",
	"version": "0.0.35"
}
